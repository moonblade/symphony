{
  "name": "symphony",
  "version": "1.0.0",
  "description": "Issue orchestration service that runs opencode agents per Linear issue",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "symphony": "dist/cli.js",
    "symphony-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:ui": "tsx scripts/build-ui.ts",
    "build:ui:watch": "tsx scripts/build-ui.ts --watch",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@linear/sdk": "^29.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.2.24",
    "@types/node-telegram-bot-api": "^0.64.14",
    "better-sqlite3": "^12.6.2",
    "botbuilder": "^4.23.3",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "htm": "^3.1.1",
    "liquidjs": "^10.21.0",
    "node-telegram-bot-api": "^0.67.0",
    "preact": "^10.29.0",
    "unique-names-generator": "^4.7.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@tailwindcss/cli": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chokidar": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
